# Database Configuration
# For Render/Production: use your MySQL provider's connection details
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=filmverse

# JWT Secret - IMPORTANT: Use a strong random string for production
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This must match between dev and production for token validation
JWT_SECRET=your_jwt_secret

# TMDB API Key - Get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# Server Port (change to 5001 or your preferred port)
PORT=5001
